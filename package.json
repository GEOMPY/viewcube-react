{
  "name": "@geo-mpy/viewcube-react",
  "version": "1.0.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean:dist": "rm -rf dist",
    "dev": "vite",
    "build": "vite build && npm run check:dts && npm run check:exports",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:app",
    "test": "vitest run",
    "lint": "eslint .",
    "smoke:sample": "node ./scripts/smoke-sample-r3f.mjs",
    "verify:qa": "npm run lint && npm run typecheck:all && npm run test && npm run smoke:sample",
    "preview": "vite preview",
    "check:peers": "node ./scripts/check-peer-deps.mjs",
    "check:entries": "node ./scripts/check-entry-files.mjs",
    "check:exports": "node ./scripts/check-exports.mjs",
    "check:dts": "node ./scripts/check-dts.mjs",
    "check:readme": "node ./scripts/check-readme.mjs",
    "check:pack": "node ./scripts/check-pack-contents.mjs",
    "check:esm": "node ./scripts/check-esm-only.mjs",
    "smoke:packed": "node ./scripts/smoke-packed-consumer.mjs",
    "phase0:check": "npm run check:peers && npm run check:entries",
    "phase1:check": "npm run typecheck && npm run build",
    "phase2:check": "npm run typecheck && npm run test",
    "phase3:check": "npm run typecheck && npm run test",
    "phase4:check": "npm run typecheck && npm run test",
    "phase9:check": "npm run verify:qa",
    "phase10:check": "npm run check:readme && npm run smoke:sample && npm run typecheck:app",
    "phase11:check": "npm run clean:dist && npm run verify:qa && npm run build && npm run check:esm && npm run check:pack && npm run smoke:packed"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "@react-three/drei": {
      "optional": false
    },
    "@react-three/fiber": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "three": {
      "optional": false
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-test-renderer": "^19.2.0",
    "three": "^0.180.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
